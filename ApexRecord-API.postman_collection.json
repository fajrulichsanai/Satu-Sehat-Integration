{
  "info": {
    "name": "ApexRecord API",
    "_postman_id": "apexrecord-satusehat-collection-v1",
    "description": "Sistem Manajemen Klinik Kesehatan dengan integrasi SATUSEHAT\n\n## Setup\n1. Set variable `baseUrl` ke URL server (default: http://localhost:3001)\n2. Login via `POST /auth/login`, copy `accessToken` dari response\n3. Set variable `token` dengan nilai accessToken tersebut\n4. Semua request berprotected akan otomatis menggunakan token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT access token dari response /auth/login"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01. Auth",
      "description": "Authentication & Authorization",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@klinik.com\",\n  \"password\": \"SecurePass123!\",\n  \"name\": \"Dr. Budi Santoso\",\n  \"role\": \"owner\",\n  \"ownerCode\": \"ABC123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('token', json.data.accessToken);",
                  "  console.log('Token saved:', json.data.accessToken.substring(0, 30) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@klinik.com\",\n  \"password\": \"SecurePass123!\"\n}"
            }
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Check Activation Status",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/activation-status", "host": ["{{baseUrl}}"], "path": ["auth", "activation-status"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email?token=YOUR_VERIFICATION_TOKEN",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-email"],
              "query": [{ "key": "token", "value": "YOUR_VERIFICATION_TOKEN" }]
            }
          }
        }
      ]
    },
    {
      "name": "02. Users",
      "description": "User Management (Role: OWNER)",
      "item": [
        {
          "name": "Get All Users",
          "request": {
